      <div class="portrait-title">
        <h2>Dr Lukas Wallrich</h2>
        <h3>Senior Lecturer</h3>

        
        <h3>
          <a href="https://www.bbk.ac.uk/" target="_blank" rel="noopener">
          <span>Birkbeck, University of London</span>
          </a>
        </h3>
        
      </div>

